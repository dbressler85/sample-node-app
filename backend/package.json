{
  "name": "dynasty-central-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Aggregation backend for managing multiple MyFantasyLeague dynasty leagues",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "lint": "eslint src scripts test",
    "sync:trade-math": "node scripts/sync-trade-math.js",
    "smoke": "node scripts/smoke.js",
    "smoke:live": "node scripts/smoke-live.js",
    "smoke:all": "node scripts/smoke.js && node scripts/smoke-live.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^8.57.1"
  }
}
