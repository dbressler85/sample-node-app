# Copy to .env (or set these in your host's dashboard) and fill in.

# Port the backend listens on.
PORT=4000

# Fantasy season year (MFL scopes all data by year). Defaults to current year.
MFL_SEASON=2026

# DEMO MODE — serves fixture data, no MFL account needed. Great for first run.
# Set to false to make real MyFantasyLeague calls.
MFL_DEMO_MODE=true

# Identify your client to MFL. High-volume use should register in the MFL
# Developers Program and set an API key.
MFL_USER_AGENT=dynasty-central/0.1 (personal multi-league manager)
# MFL_API_KEY=

# Politeness throttle between outbound MFL requests (ms).
MFL_MIN_REQUEST_INTERVAL_MS=500

# How long to cache the global player database (ms). Default 24h.
MFL_PLAYERS_TTL_MS=86400000
